# Frontier Corm — Environment Variables
# Copy to .env and fill in values:  cp .env.example .env

# ── Sui Network ────────────────────────────────────────────────────
SUI_RPC_URL=http://127.0.0.1:9000
# SUI_WS_URL=ws://127.0.0.1:9000

# ── Deployed Package IDs (set after `sui client publish`) ──────────
PACKAGE_TRIBE=
PACKAGE_CORM_AUTH=
PACKAGE_TRUSTLESS_CONTRACTS=
PACKAGE_WITNESSED_CONTRACTS=
PACKAGE_CORM_STATE=
PACKAGE_ASSEMBLY_METADATA=

# ── Web App (Vite — auto-populated by publish/deploy scripts) ──────
VITE_WEB_UI_HOST=http://localhost:5173
VITE_TRIBE_PACKAGE_ID=
VITE_TRIBE_REGISTRY_ID=
VITE_CORM_AUTH_PACKAGE_ID=
VITE_TRUSTLESS_CONTRACTS_PACKAGE_ID=
VITE_WITNESSED_CONTRACTS_PACKAGE_ID=
VITE_CORM_STATE_PACKAGE_ID=
VITE_CORM_CONFIG_ID=
VITE_ASSEMBLY_METADATA_PACKAGE_ID=
VITE_METADATA_REGISTRY_ID=
VITE_WORLD_PACKAGE_ID=

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://corm:corm@localhost:5432/frontier_corm

# ── Indexer ────────────────────────────────────────────────────────
INDEXER_API_URL=http://localhost:3100
API_PORT=3100
POLL_INTERVAL_MS=2000

# ── Puzzle Service ──────────────────────────────────────────────────
PUZZLE_PORT=3300
# PUZZLE_SERVICE_URL=http://localhost:3300   # corm-brain → puzzle-service

# ── Corm Brain (LLM + memory) ──────────────────────────────────────
# LLM_SUPER_URL=http://localhost:8000       # TRT-LLM Super (via DGX tunnel)
# LLM_FAST_URL=http://localhost:8001        # TRT-LLM Nano (via DGX tunnel)
# EMBED_MODEL_PATH=./models/nomic-embed     # nomic-embed-text ONNX model dir
# SUI_PRIVATE_KEY=                          # Ed25519 keypair for corm-brain txns
# CORM_STATE_PACKAGE_ID=                    # set by publish-contracts-local.sh
# ENVIRONMENTS_CONFIG=                      # path to environments.json (multi-env)
# CONSOLIDATION_INTERVAL_MS=60000
# MEMORY_CAP_PER_CORM=500
# EVENT_COALESCE_MS=50
# WS_RECONNECT_MAX_MS=30000
# FALLBACK_POLL_INTERVAL_MS=2000

# ── DGX Spark (SSH remote for TRT-LLM models) ─────────────────────
# DGX_HOST=dgx-spark.local
# DGX_USER=              # defaults to $USER if unset
# DGX_WORK_DIR=~/frontier-corm   # remote dir for configs + containers

# ── AWS (for deployment scripts) ───────────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=
