# Frontier Corm — Stillness Environment Variables
# Copy to .env.stillness and fill in values:  cp .env.stillness.example .env.stillness
# Contract IDs are populated automatically by: make publish-contracts ENV=stillness

# ── Sui Network ────────────────────────────────────────────────────
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet

# ── World Package (Stillness on testnet) ───────────────────────────
VITE_WORLD_PACKAGE_ID=0x28b497559d65ab320d9da4613bf2498d5946b2c0ae3597ccfda3072ce127448c
VITE_ENERGY_CONFIG_ID=0xd77693d0df5656d68b1b833e2a23cc81eb3875d8d767e7bd249adde82bdbc952

# ── Deployed Package IDs (populated by publish-contracts.sh) ───────
PACKAGE_TRIBE=
PACKAGE_CORM_AUTH=
PACKAGE_TRUSTLESS_CONTRACTS=
PACKAGE_WITNESSED_CONTRACTS=
PACKAGE_CORM_STATE=
PACKAGE_ASSEMBLY_METADATA=

# ── Web App (Vite — populated by publish-contracts.sh) ─────────────
VITE_WEB_UI_HOST=
VITE_SUI_NETWORK=testnet
VITE_TRIBE_PACKAGE_ID=
VITE_TRIBE_REGISTRY_ID=
VITE_CORM_AUTH_PACKAGE_ID=
VITE_TRUSTLESS_CONTRACTS_PACKAGE_ID=
VITE_WITNESSED_CONTRACTS_PACKAGE_ID=
VITE_CORM_STATE_PACKAGE_ID=
VITE_CORM_CONFIG_ID=
VITE_ASSEMBLY_METADATA_PACKAGE_ID=
VITE_METADATA_REGISTRY_ID=
VITE_COIN_TYPE=0x2::sui::SUI
VITE_INDEXER_URL=/api/v1
VITE_WORLD_API_URL=https://world-api-stillness.live.tech.evefrontier.com

# ── Continuity Engine ──────────────────────────────────────────────
VITE_CONTINUITY_ENGINE_URL=https://continuity-engine.ef-corm.com

# ── Database (resolved from CDK outputs at deploy time) ────────────
# DATABASE_URL is constructed at container startup from Secrets Manager.
# Only set this if running the indexer outside of ECS.
# DATABASE_URL=

# ── Indexer ────────────────────────────────────────────────────────
INDEXER_API_URL=
API_PORT=3100
POLL_INTERVAL_MS=2000

# ── AWS ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=frontier-corm
