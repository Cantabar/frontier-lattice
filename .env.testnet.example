# Frontier Corm — Testnet Environment Variables
# Copy to .env.testnet and fill in values:  cp .env.testnet.example .env.testnet
# Contract IDs are populated automatically by: make publish-testnet

# ── Sui Network ────────────────────────────────────────────────────
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet

# ── Deployed Package IDs (populated by publish-testnet.sh) ─────────
PACKAGE_TRIBE=
PACKAGE_CORM_AUTH=
PACKAGE_TRUSTLESS_CONTRACTS=

# ── World Package (must be deployed separately) ────────────────────
VITE_WORLD_PACKAGE_ID=
VITE_ENERGY_CONFIG_ID=

# ── Web App (Vite — populated by publish-testnet.sh) ───────────────
VITE_WEB_UI_HOST=
VITE_SUI_NETWORK=testnet
VITE_TRIBE_PACKAGE_ID=
VITE_TRIBE_REGISTRY_ID=
VITE_CORM_AUTH_PACKAGE_ID=
VITE_TRUSTLESS_CONTRACTS_PACKAGE_ID=
VITE_COIN_TYPE=0x2::sui::SUI
VITE_INDEXER_URL=/api/v1

# ── Database (resolved from CDK outputs at deploy time) ────────────
# DATABASE_URL is constructed at container startup from Secrets Manager.
# Only set this if running the indexer outside of ECS.
# DATABASE_URL=

# ── Indexer ────────────────────────────────────────────────────────
INDEXER_API_URL=
API_PORT=3100
POLL_INTERVAL_MS=2000

# ── AWS ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=frontier-corm
