# Frontier Corm — Utopia Environment Variables
# Copy to .env.utopia and fill in values:  cp .env.utopia.example .env.utopia
# Contract IDs are populated automatically by: make publish-contracts ENV=utopia

# ── Sui Network ────────────────────────────────────────────────────
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_NETWORK=testnet

# ── World Package (Utopia on testnet) ──────────────────────────────
VITE_WORLD_PACKAGE_ID=0xd12a70c74c1e759445d6f209b01d43d860e97fcf2ef72ccbbd00afd828043f75
VITE_ENERGY_CONFIG_ID=0x9285364e8104c04380d9cc4a001bbdfc81a554aad441c2909c2d3bd52a0c9c62

# ── Deployed Package IDs (populated by publish-contracts.sh) ───────
PACKAGE_TRIBE=
PACKAGE_CORM_AUTH=
PACKAGE_TRUSTLESS_CONTRACTS=
PACKAGE_WITNESSED_CONTRACTS=
PACKAGE_CORM_STATE=
PACKAGE_ASSEMBLY_METADATA=

# ── Web App (Vite — populated by publish-contracts.sh) ─────────────
VITE_WEB_UI_HOST=
VITE_SUI_NETWORK=testnet
VITE_TRIBE_PACKAGE_ID=
VITE_TRIBE_REGISTRY_ID=
VITE_CORM_AUTH_PACKAGE_ID=
VITE_TRUSTLESS_CONTRACTS_PACKAGE_ID=
VITE_WITNESSED_CONTRACTS_PACKAGE_ID=
VITE_CORM_STATE_PACKAGE_ID=
VITE_CORM_CONFIG_ID=
VITE_ASSEMBLY_METADATA_PACKAGE_ID=
VITE_METADATA_REGISTRY_ID=
VITE_COIN_TYPE=0x2::sui::SUI
VITE_INDEXER_URL=/api/v1
VITE_WORLD_API_URL=https://world-api-utopia.live.tech.evefrontier.com

# ── Database (resolved from CDK outputs at deploy time) ────────────
# DATABASE_URL is constructed at container startup from Secrets Manager.
# Only set this if running the indexer outside of ECS.
# DATABASE_URL=

# ── Indexer ────────────────────────────────────────────────────────
INDEXER_API_URL=
API_PORT=3100
POLL_INTERVAL_MS=2000

# ── AWS ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=frontier-corm
