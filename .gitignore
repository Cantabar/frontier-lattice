.DS_Store
node_modules/
build/
target/
dist/
*.key

# Environment (contains secrets)
.env
.env.*
**/.env
**/.env.*

# CDK
infra/cdk.out/

# Indexer runtime data
indexer/data/

# Reference clone — not our code
world-contracts/

# Static game data (large binary/embedded repos) — ignore bulk, allow curated files
static-data/*
!static-data/design-doc.md
!static-data/data
static-data/data/*
!static-data/data/icons
!static-data/data/phobos
static-data/data/phobos/*
!static-data/data/phobos/fsd_built
static-data/data/phobos/fsd_built/*
!static-data/data/phobos/fsd_built/types.json
!static-data/data/phobos/fsd_built/industry_blueprints.json

# Move ephemeral publication metadata (regenerated on each publish)
Pub.local.toml
Pub.localnet.toml
Pub.utopia.toml
Pub.stillness.toml

# ONNX model weights (large binaries, downloaded at runtime)
models/

# mprocs runtime log
mprocs.log

# mprocs coordination markers
.world-ready

dev-tools/*
!dev-tools/design-doc.md
!dev-tools/dev-wallet
!dev-tools/give-item-helper
!dev-tools/world-contract-tracker

# corm-brain compiled binary
corm-brain/corm-brain

# TypeScript incremental build cache
*.tsbuildinfo

# ZK circuit generated artifacts
indexer/circuits/build/
indexer/circuits/*.ptau
indexer/circuits/artifacts/*
!indexer/circuits/artifacts/.gitkeep
web/public/zk/*
!web/public/zk/.gitkeep
