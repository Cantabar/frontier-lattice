# Frontier Corm — Local environment (mock APIs, localnet SUI)
# Loaded via: vite --mode localnet

VITE_APP_ENV=local
VITE_SUI_NETWORK=localnet
VITE_PUZZLE_SERVICE_URL=http://localhost:3300

# CORM coin type (set after deploying corm_coin package)
# VITE_CORM_COIN_TYPE=

# corm_state package ID (populated by publish-contracts-local.sh)
# VITE_CORM_STATE_PACKAGE_ID=
