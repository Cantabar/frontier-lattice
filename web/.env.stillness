# Frontier Corm — Stillness environment
# Loaded via: vite --mode stillness

VITE_APP_ENV=stillness
VITE_SUI_NETWORK=testnet
VITE_WORLD_API_URL=https://world-api-stillness.live.tech.evefrontier.com

# Sui RPC: use fullnode directly (CORS supported, avoids CloudFront proxy issues)
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# World contract IDs (from https://docs.evefrontier.com/tools/resources)
VITE_WORLD_PACKAGE_ID=0x28b497559d65ab320d9da4613bf2498d5946b2c0ae3597ccfda3072ce127448c
VITE_ENERGY_CONFIG_ID=0xd77693d0df5656d68b1b833e2a23cc81eb3875d8d767e7bd249adde82bdbc952

# CORM coin type — derived from the deployed corm_state package address
VITE_CORM_COIN_TYPE=0xde73977e2e9ec7c219dc35dac8386d88427e945c109634b2aeadb1c03eeaffa6::corm_coin::CORM_COIN

# Deployed Corm contract IDs (populated by publish-contracts.sh)
